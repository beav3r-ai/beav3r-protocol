# Contracts-local env (preferred for forge/bun commands in this folder)

# RPC
ONCHAIN_PROVISION_RPC_URL=http://127.0.0.1:8545
ONCHAIN_CHAIN_ID=31337

# Deployer key. The deployer becomes the initial registry owner and registrar.
PRIVATE_KEY=0xreplace-with-private-key

# Contract verification
ETHERSCAN_API_KEY=replace-with-etherscan-api-key

# Beav3r API provisioning script
BEAV3R_BASE_URL=http://127.0.0.1:3000
BEAV3R_API_KEY=beav3r_live_or_test_key
ONCHAIN_INTENDED_OWNER=0xreplace-with-owner-address
ONCHAIN_ACTOR_LABEL=Demo executor
BEAV3R_PROJECT_ID=project_replace_with_project_id
